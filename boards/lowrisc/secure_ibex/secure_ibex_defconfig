CONFIG_SERIAL=y
CONFIG_CONSOLE=y
CONFIG_UART_CONSOLE=y
CONFIG_UART_INTERRUPT_DRIVEN=y
CONFIG_BUILD_OUTPUT_BIN=y
CONFIG_XIP=n

# Shell support — uses polling backend because the Ibex UART has no
# hardware TX interrupt (only RX IRQ). The interrupt-driven TX path
# stalls after the first FIFO fill since no ISR fires to refill it.
CONFIG_SHELL=y
CONFIG_SHELL_BACKEND_SERIAL=y
CONFIG_SHELL_BACKEND_SERIAL_API_POLLING=y
